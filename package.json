{
	"name": "pulsehub",
	"version": "1.0.0",
	"main": "public/electron.js",
	"homepage": "./",
	"description": "A multipurpose, open-sourced music player",
	"author": {
		"name": "Wiwok",
		"url": "https://github.com/Wiwok"
	},
	"authors": [
		{
			"name": "Wiwok",
			"url": "https://github.com/Wiwok"
		},
		{
			"name": "UnelDev",
			"url": "https://github.com/UnelDev"
		}
	],
	"build": {
		"appId": "com.wiwok.pulsehub",
		"productName": "Pulse Hub",
		"files": [
			"build/**/*",
			"node_modules/**/*"
		],
		"directories": {
			"buildResources": "public"
		},
		"win": {
			"target": "nsis"
		}
	},
	"scripts": {
		"start": "react-scripts start",
		"rbuild": "react-scripts build",
		"ebuild": "electron-builder -w -c.extraMetadata.main=build/electron.js",
		"dev": "concurrently -k \"cross-env BROWSER=none npm start\" \"npm:electron\"",
		"electron": "wait-on http://127.0.0.1:3000 && electron .",
		"build": "npm run rbuild && npm run ebuild"
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	},
	"dependencies": {
		"axios": "^1.5.1",
		"fluent-ffmpeg": "^2.1.2",
		"https": "^1.0.0",
		"node-id3": "^0.2.6",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"react-youtube": "^10.1.0",
		"ytdl-core": "git+ssh://git@github.com:khlevon/node-ytdl-core.git#v4.11.4-patch.2",
		"ytmusic-api": "^4.3.0"
	},
	"devDependencies": {
		"@babel/plugin-proposal-private-property-in-object": "^7.21.11",
		"@types/react": "^18.2.23",
		"@types/react-dom": "^18.2.7",
		"concurrently": "^8.2.1",
		"cross-env": "^7.0.3",
		"electron": "^26.2.2",
		"electron-builder": "^24.6.4",
		"react-scripts": "5.0.1",
		"wait-on": "^7.0.1"
	}
}
